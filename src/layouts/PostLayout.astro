---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SubscribeForm from '../components/SubscribeForm.astro';

type Props = CollectionEntry<'posts'>['data'] & { readingTime: number };

const { title, description, pubDate, coverImage, readingTime, author } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={coverImage} />
	</head>
	<body>
		<Header />

		<!-- Hero image: 95vw, full-bleed feel, outside the article container -->
		{coverImage && (
			<div class="cover-image">
				<img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${coverImage}`} alt={title} loading="eager" />
			</div>
		)}

		<main>
			<article>
				<header class="post-header">
					<div class="post-meta">
						{author && <><span>{author}</span><span class="separator">·</span></>}
						<time datetime={pubDate.toISOString()}>{formattedDate}</time>
						<span class="separator">·</span>
						<span>{readingTime} min read</span>
					</div>
					<h1>{title}</h1>
					{description && <p class="description">{description}</p>}
					<hr />
				</header>

				<div class="prose">
					<slot />
				</div>
			</article>

			<SubscribeForm />

			<div class="back-link">
				<a href={import.meta.env.BASE_URL}>&larr; All posts</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero image: 95vw centred, square edges, full-impact */
	.cover-image {
		width: 95vw;
		margin: 0 auto var(--space-xl);
		display: block;
	}

	.cover-image img {
		width: 100%;
		height: clamp(300px, 55vh, 720px);
		object-fit: cover;
		border-radius: 0;
		display: block;
	}

	/* Article body: 75% width centred */
	main {
		width: var(--content-width);
		max-width: calc(100% - clamp(2rem, 5vw, 4rem));
		margin: 0 auto;
		padding: 0 0 var(--space-xl);
	}

	article {
		width: 100%;
	}

	.post-header {
		margin-bottom: var(--space-xl);
	}

	.post-meta {
		font-family: var(--font-ui);
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin-bottom: var(--space-sm);
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.separator {
		opacity: 0.4;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(2.25rem, 4.5vw, 4rem);
		font-weight: 700;
		line-height: 1.1;
		margin: var(--space-sm) 0;
		letter-spacing: -0.02em;
	}

	.description {
		font-size: 1.2rem;
		color: var(--color-text-muted);
		margin: var(--space-sm) 0 0;
		line-height: 1.55;
		font-style: italic;
	}

	hr {
		margin: var(--space-lg) 0;
	}

	/* Prose: 1.25rem / 1.7 per brief */
	.prose {
		font-size: 1.25rem;
		line-height: 1.7;
	}

	/* Images within prose can break out wider than the text column */
	.prose :global(img) {
		display: block;
		width: min(95vw, 1440px);
		max-width: min(95vw, 1440px);
		margin: 2em auto;
		margin-left: calc(50% - min(47.5vw, 720px));
		border-radius: 0;
	}

	.back-link {
		margin: var(--space-xl) 0 0;
		font-family: var(--font-ui);
		font-size: 0.9rem;
	}

	.back-link a {
		color: var(--color-text-muted);
	}

	.back-link a:hover {
		color: var(--color-accent);
	}

	/* ── Responsive ────────────────────────────────────── */
	@media (max-width: 860px) {
		.cover-image {
			width: 100%;
		}

		h1 {
			font-size: 2rem;
		}

		.prose :global(img) {
			width: 100%;
			max-width: 100%;
			margin-left: 0;
		}
	}

	@media (max-width: 600px) {
		main {
			max-width: calc(100% - 2rem);
		}

		.cover-image {
			width: 100%;
			margin-bottom: var(--space-lg);
		}

		h1 {
			font-size: 1.75rem;
		}

		.prose {
			font-size: 1.1rem;
		}
	}
</style>
