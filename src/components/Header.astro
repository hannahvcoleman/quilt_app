---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="header-inner">
		<!-- Masthead: QUILLT wordmark -->
		<a href={import.meta.env.BASE_URL} class="masthead-link" aria-label="Quillt – home">
			<span class="masthead-wordmark">{SITE_TITLE.toUpperCase()}</span>
		</a>

		<!-- Nav links -->
		<nav class="nav-links" aria-label="Site navigation">
			<a href={`${import.meta.env.BASE_URL}posts`} class="nav-btn">Posts</a>
			<a href={`${import.meta.env.BASE_URL}subscribe`} class="nav-btn">Subscribe</a>
			<a href={`${import.meta.env.BASE_URL}about`} class="nav-btn">About</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: var(--color-bg);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 40px 60px;
	}

	/* ── Masthead ────────────────────────────────────────────────── */
	.masthead-link {
		text-decoration: none;
		display: block;
		line-height: 1;
	}

	.masthead-link:hover {
		text-decoration: none;
	}

	.masthead-wordmark {
		display: block;
		font-family: var(--font-masthead);
		font-size: clamp(8rem, 12vw, 12rem);
		font-weight: 400; /* Archivo Black is always 900 — weight: 400 selects the Black face */
		letter-spacing: -6px;
		line-height: 0.85;
		color: var(--color-text);
		transition: color 0.15s;
		user-select: none;
	}

	.masthead-link:hover .masthead-wordmark {
		color: var(--color-accent);
	}

	/* ── Nav links ───────────────────────────────────────────────── */
	.nav-links {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.nav-btn {
		font-family: var(--font-ui);
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
		border: 1px solid var(--color-text);
		border-radius: 0;
		padding: 8px 15px;
		transition: background 0.15s, color 0.15s;
	}

	.nav-btn:hover {
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
	}

	/* ── Responsive ─────────────────────────────────────────────── */
	@media (max-width: 860px) {
		.header-inner {
			padding: 28px 2rem;
		}

		.masthead-wordmark {
			font-size: clamp(5rem, 8vw, 7rem);
			letter-spacing: -4px;
		}
	}

	@media (max-width: 600px) {
		.header-inner {
			padding: 20px 1rem;
		}

		.masthead-wordmark {
			font-size: clamp(3rem, 10vw, 4rem);
			letter-spacing: -2.5px;
		}

		.nav-links {
			gap: 6px;
		}

		.nav-btn {
			padding: 6px 10px;
			font-size: 0.72rem;
		}
	}
</style>
