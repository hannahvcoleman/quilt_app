---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="header-inner">
		<!-- Masthead: QUILLT wordmark -->
		<a href={import.meta.env.BASE_URL} class="masthead-link" aria-label="Quillt – home">
			<span class="masthead-wordmark">{SITE_TITLE.toUpperCase()}</span>
		</a>

	</div>
</header>

<style>
	.site-header {
		background: var(--color-bg);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 40px 60px;
	}

	/* ── Masthead ────────────────────────────────────────────────── */
	.masthead-link {
		text-decoration: none;
		display: block;
		line-height: 1;
	}

	.masthead-link:hover {
		text-decoration: none;
	}

	.masthead-wordmark {
		display: block;
		font-family: var(--font-masthead);
		font-size: clamp(8rem, 12vw, 12rem);
		font-weight: 400; /* Archivo Black is always 900 — weight: 400 selects the Black face */
		letter-spacing: -6px;
		line-height: 0.85;
		color: var(--color-text);
		transition: color 0.15s;
		user-select: none;
	}

	.masthead-link:hover .masthead-wordmark {
		color: var(--color-accent);
	}


	/* ── Responsive ─────────────────────────────────────────────── */
	@media (max-width: 860px) {
		.header-inner {
			padding: 28px 2rem;
		}

		.masthead-wordmark {
			font-size: clamp(5rem, 8vw, 7rem);
			letter-spacing: -4px;
		}
	}

	@media (max-width: 600px) {
		.header-inner {
			padding: 20px 1rem;
		}

		.masthead-wordmark {
			font-size: clamp(3rem, 10vw, 4rem);
			letter-spacing: -2.5px;
		}
	}
</style>
