---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<!-- Top bar: nav links sit top-right -->
	<div class="header-topbar">
		<div class="nav-links">
			<a href={`${import.meta.env.BASE_URL}posts`} class="nav-posts">Posts</a>
			<a href={`${import.meta.env.BASE_URL}subscribe`}>Subscribe</a>
			<a href={`${import.meta.env.BASE_URL}about`}>About</a>
		</div>
	</div>

	<!-- Masthead: QUILLT wordmark -->
	<div class="masthead-wrap">
		<a href={import.meta.env.BASE_URL} class="masthead-link" aria-label="Quillt – home">
			<span class="masthead-wordmark">{SITE_TITLE.toUpperCase()}</span>
		</a>
	</div>

	<!-- Category / tag strip -->
	<nav class="tag-strip" aria-label="Browse by category">
		<a href={import.meta.env.BASE_URL} class="tag-btn active" aria-current="true">All</a>
		<a href={`${import.meta.env.BASE_URL}?tag=culture`} class="tag-btn">Culture</a>
		<a href={`${import.meta.env.BASE_URL}?tag=technology`} class="tag-btn">Technology</a>
		<a href={`${import.meta.env.BASE_URL}?tag=design`} class="tag-btn">Design</a>
		<a href={`${import.meta.env.BASE_URL}?tag=essays`} class="tag-btn">Essays</a>
		<a href={`${import.meta.env.BASE_URL}?tag=interviews`} class="tag-btn">Interviews</a>
	</nav>
</header>

<style>
	.site-header {
		background: var(--color-bg);
		border-bottom: 2px solid var(--color-text);
	}

	/* ── Top bar ─────────────────────────────────────────────────── */
	.header-topbar {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		padding: 0.75rem 60px;
		border-bottom: 1px solid var(--color-border);
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-links a {
		font-family: var(--font-ui);
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
		transition: color 0.15s;
	}

	.nav-links a:hover {
		color: var(--color-accent);
		text-decoration: none;
	}

	/* ── Masthead ────────────────────────────────────────────────── */
	.masthead-wrap {
		padding: 40px 60px;
		display: flex;
		align-items: flex-end;
	}

	.masthead-link {
		text-decoration: none;
		display: block;
		line-height: 1;
	}

	.masthead-link:hover {
		text-decoration: none;
	}

	.masthead-wordmark {
		display: block;
		font-family: var(--font-masthead);
		font-size: clamp(4rem, 8vw, 8rem);
		font-weight: 400; /* Archivo Black is always 900 — weight: 400 selects the Black face */
		letter-spacing: -5px;
		line-height: 0.85;
		color: var(--color-text);
		transition: color 0.15s;
		user-select: none;
	}

	.masthead-link:hover .masthead-wordmark {
		color: var(--color-accent);
	}

	/* ── Responsive ─────────────────────────────────────────────── */
	@media (max-width: 860px) {
		.header-topbar {
			padding: 0.75rem 1.5rem;
		}

		.masthead-wrap {
			padding: 28px 1.5rem;
		}

		.masthead-wordmark {
			letter-spacing: -3px;
		}
	}

	@media (max-width: 600px) {
		.header-topbar {
			padding: 0.6rem 1rem;
		}

		.nav-links {
			gap: 1.25rem;
		}

		.nav-posts {
			display: none;
		}

		.masthead-wrap {
			padding: 20px 1rem 16px;
		}

		.masthead-wordmark {
			letter-spacing: -2px;
		}

		/* Tag strip: scroll horizontally on small screens */
		:global(.tag-strip) {
			flex-wrap: nowrap;
		}
	}
</style>
