---
import { Image } from 'astro:assets';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/content/posts/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP}'
);

interface Props {
	src?: string;
	alt?: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;

function normalizeExt(s: string): string {
	const dot = s.lastIndexOf('.');
	if (dot === -1) return s;
	let ext = s.slice(dot).toLowerCase();
	if (ext === '.jpeg') ext = '.jpg';
	return s.slice(0, dot) + ext;
}

async function resolveImage(s: string): Promise<ImageMetadata | null> {
	const normalised = normalizeExt(s).replace(/^\.\//, '');
	const key = Object.keys(allImages).find((k) =>
		normalizeExt(k).endsWith('/' + normalised)
	);
	if (key) {
		const mod = await allImages[key]();
		return mod.default;
	}
	console.warn(`[Image70] could not resolve image: "${s}"`);
	return null;
}

const resolved = src ? await resolveImage(src) : null;
---

{resolved && (
<figure class="image-70">
	<Image src={resolved} alt={alt ?? ''} loading="lazy" />
	{caption && <figcaption>{caption}</figcaption>}
</figure>
)}

<style>
	.image-70 {
		display: block;
		width: 70%;
		margin: 2em auto;
	}

	.image-70 img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 4px;
		margin: 0;
	}

	figcaption {
		font-family: var(--font-ui);
		font-size: 0.75rem;
		color: var(--color-text-muted);
		padding: 0.5rem 0;
		text-align: center;
	}

	@media (max-width: 860px) {
		.image-70 {
			width: 100%;
		}
	}
</style>
