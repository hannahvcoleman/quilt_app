---
import { Image } from 'astro:assets';

// Eagerly index every image across all posts at build time.
// Keys are absolute Vite module paths, e.g. /src/content/posts/boo/bauhaus.png
const allImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/content/posts/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP}'
);

interface GalleryImage {
	src?: string;
	alt?: string;
	caption?: string;
}

interface Props {
	images: GalleryImage[];
	layout?: '2x1' | '3x1' | '2x2' | '3x3';
}

const { images = [], layout } = Astro.props;

// Normalise extension: lowercase + .jpeg → .jpg
function normalizeExt(s: string): string {
	const dot = s.lastIndexOf('.');
	if (dot === -1) return s;
	let ext = s.slice(dot).toLowerCase();
	if (ext === '.jpeg') ext = '.jpg';
	return s.slice(0, dot) + ext;
}

// Resolve a relative src string like "./DSCF0359.jpg" to ImageMetadata by
// matching its normalised basename against the glob index.
async function resolveImage(src: string): Promise<ImageMetadata | null> {
	// Normalise: lowercase ext, .jpeg → .jpg, strip leading ./
	const normalised = normalizeExt(src).replace(/^\.\//, '');

	// Search glob keys for a path ending with /<normalised filename>
	const key = Object.keys(allImages).find((k) =>
		normalizeExt(k).endsWith('/' + normalised)
	);

	if (key) {
		const mod = await allImages[key]();
		return mod.default;
	}

	console.warn(`[Gallery] could not resolve image: "${src}"`);
	return null;
}

// Auto-detect layout from image count if not specified
function autoLayout(count: number): string {
	if (count === 2) return '2x1';
	if (count === 3) return '3x1';
	if (count === 4) return '2x2';
	if (count >= 6 && count <= 9) return '3x3';
	return '2x1';
}

const resolvedLayout = layout ?? autoLayout(images.length);
const cols = resolvedLayout.startsWith('3') ? 3 : 2;

// Resolve all images in parallel before rendering
const resolvedImages = await Promise.all(
	images.map(async (img) => ({
		...img,
		resolved: img.src ? await resolveImage(img.src) : null,
	}))
);
---

<figure class="gallery" data-layout={resolvedLayout} style={`--cols: ${cols}`}>
	{resolvedImages.map((img) => (
		<div class="gallery-item">
			{img.resolved
				? <Image src={img.resolved} alt={img.alt ?? ''} loading="lazy" />
				: img.src
					? <div class="gallery-placeholder" title={`Missing: ${img.src}`} />
					: null
			}
			{img.caption && <figcaption>{img.caption}</figcaption>}
		</div>
	))}
</figure>

<style>
	.gallery {
		display: grid;
		grid-template-columns: repeat(var(--cols), 1fr);
		gap: 0.375rem;
		margin: 2em 0;
		max-width: var(--wide-width);
		width: calc(100% + clamp(2rem, 8vw, 6rem) * 2);
		margin-left: calc(-1 * clamp(2rem, 8vw, 6rem));
	}

	.gallery-item {
		overflow: hidden;
		border-radius: 4px;
		aspect-ratio: 3 / 2;
		background: var(--color-border);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		box-shadow: none;
		margin: 0;
	}

	.gallery-placeholder {
		width: 100%;
		height: 100%;
		background: var(--color-border);
	}

	figcaption {
		font-family: var(--font-ui);
		font-size: 0.75rem;
		color: var(--color-text-muted);
		padding: 0.25rem 0;
		text-align: center;
	}

	@media (max-width: 860px) {
		.gallery {
			width: 100%;
			margin-left: 0;
		}
	}

	@media (max-width: 600px) {
		.gallery {
			grid-template-columns: repeat(2, 1fr);
		}

		.gallery[data-layout="3x3"] {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
