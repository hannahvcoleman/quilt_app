---
interface Image {
	src: string;
	alt?: string;
	caption?: string;
}

interface Props {
	images: Image[];
	layout?: '2x1' | '3x1' | '2x2' | '3x3';
}

const { images = [], layout } = Astro.props;

// Auto-detect layout from image count if not specified
function autoLayout(count: number): string {
	if (count === 2) return '2x1';
	if (count === 3) return '3x1';
	if (count === 4) return '2x2';
	if (count >= 6 && count <= 9) return '3x3';
	return '2x1';
}

const resolvedLayout = layout ?? autoLayout(images.length);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function resolveUrl(src: string) {
	if (src.startsWith('http')) return src;
	return `${base}${src.startsWith('/') ? src : '/' + src}`;
}

const cols = resolvedLayout.startsWith('3') ? 3 : 2;
---

<figure class="gallery" data-layout={resolvedLayout} style={`--cols: ${cols}`}>
	{images.map((img) => (
		<div class="gallery-item">
			<img src={resolveUrl(img.src)} alt={img.alt ?? ''} loading="lazy" />
			{img.caption && <figcaption>{img.caption}</figcaption>}
		</div>
	))}
</figure>

<style>
	.gallery {
		display: grid;
		grid-template-columns: repeat(var(--cols), 1fr);
		gap: 0.375rem;
		margin: 2em 0;
		max-width: var(--wide-width);
		width: calc(100% + clamp(2rem, 8vw, 6rem) * 2);
		margin-left: calc(-1 * clamp(2rem, 8vw, 6rem));
	}

	.gallery-item {
		overflow: hidden;
		border-radius: 4px;
		aspect-ratio: 3 / 2;
		background: var(--color-border);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		box-shadow: none;
		margin: 0;
	}

	figcaption {
		font-family: var(--font-ui);
		font-size: 0.75rem;
		color: var(--color-text-muted);
		padding: 0.25rem 0;
		text-align: center;
	}

	@media (max-width: 860px) {
		.gallery {
			width: 100%;
			margin-left: 0;
		}
	}

	@media (max-width: 600px) {
		.gallery {
			grid-template-columns: repeat(2, 1fr);
		}

		.gallery[data-layout="3x3"] {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
