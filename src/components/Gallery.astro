---
import { Image } from 'astro:assets';
import { normalizeExt, autoLayout, computeMasterRatio } from '../utils/gallery-utils';

// Eagerly index every image across all posts at build time.
// Keys are absolute Vite module paths, e.g. /src/content/posts/boo/bauhaus.png
const allImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/content/posts/**/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP}'
);

interface GalleryImage {
	src?: string;
	alt?: string;
	caption?: string;
}

interface Props {
	images: GalleryImage[];
	layout?: '2x1' | '3x1' | '2x2' | '3x3';
}

const { images = [], layout } = Astro.props;

// Resolve a relative src string like "./DSCF0359.jpg" to ImageMetadata by
// matching its normalised basename against the glob index.
async function resolveImage(src: string): Promise<ImageMetadata | null> {
	const normalised = normalizeExt(src).replace(/^\.\//, '');
	const key = Object.keys(allImages).find((k) =>
		normalizeExt(k).endsWith('/' + normalised)
	);
	if (key) {
		const mod = await allImages[key]();
		return mod.default;
	}
	console.warn(`[Gallery] could not resolve image: "${src}"`);
	return null;
}

const resolvedLayout = layout ?? autoLayout(images.length);
const cols = resolvedLayout.startsWith('3') ? 3 : 2;
const rows = parseInt(resolvedLayout.split('x')[1]);

// Resolve all images in parallel before rendering
const resolvedImages = await Promise.all(
	images.map(async (img) => ({
		...img,
		resolved: img.src ? await resolveImage(img.src) : null,
	}))
);

// Derive Master Ratio from the first resolved image.
// Fallback to 1:1 if no valid image is present.
const masterRatio = computeMasterRatio(resolvedImages);

// Target output width for Astro image optimisation.
// Height is derived from the master ratio so the source is pre-cropped correctly.
const OUTPUT_WIDTH = 800;
const outputHeight = Math.round(OUTPUT_WIDTH / masterRatio);
---

<figure
	class="gallery"
	data-layout={resolvedLayout}
	style={`--cols: ${cols}; --rows: ${rows}; --ratio: ${masterRatio}`}
>
	{resolvedImages.map((img) => (
		<div class="gallery-item">
			{img.resolved
				? <Image
						src={img.resolved}
						alt={img.alt ?? ''}
						width={OUTPUT_WIDTH}
						height={outputHeight}
						loading="lazy"
					/>
				: <div class="gallery-placeholder" title={img.src ? `Missing: ${img.src}` : 'Empty slot'} />
			}
			{img.caption && <figcaption>{img.caption}</figcaption>}
		</div>
	))}
</figure>

<style>
	.gallery {
		display: grid;
		grid-template-columns: repeat(var(--cols), 1fr);
		gap: 6px;
		margin: 2em 0;
		max-width: var(--wide-width);
		width: calc(100% + clamp(2rem, 8vw, 6rem) * 2);
		margin-left: calc(-1 * clamp(2rem, 8vw, 6rem));
	}

	.gallery-item {
		overflow: hidden;
		border-radius: 4px;
		aspect-ratio: 1;
		background: var(--color-border);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		border-radius: 0;
		display: block;
		box-shadow: none;
		margin: 0;
	}

	.gallery-placeholder {
		width: 100%;
		height: 100%;
		background: #f0f0f0;
	}

	figcaption {
		font-family: var(--font-ui);
		font-size: 0.75rem;
		color: var(--color-text-muted);
		padding: 0.25rem 0;
		text-align: center;
	}

	/* Desktop: fixed 360px editorial grid — all layouts share identical height */
	@media (min-width: 769px) {
		.gallery {
			height: 360px;
			grid-template-rows: repeat(var(--rows), 1fr);
		}

		.gallery-item {
			aspect-ratio: unset;
		}
	}

	@media (max-width: 860px) {
		.gallery {
			width: 100%;
			margin-left: 0;
		}
	}

	@media (max-width: 600px) {
		.gallery {
			grid-template-columns: repeat(2, 1fr);
		}

		.gallery[data-layout="3x3"] {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
