---
interface Props {
	title: string;
	description: string;
	pubDate: Date;
	slug: string;
	coverImage?: string;
	tags?: string[];
	author?: string;
}

const { title, description, pubDate, slug, coverImage, tags, author } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<article class="post-card">
	<a href={`${import.meta.env.BASE_URL}posts/${slug}`} class="card-link">
		{coverImage && (
			<div class="card-image">
				<img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${coverImage}`} alt={title} loading="lazy" />
			</div>
		)}
		<div class="card-body">
			<div class="card-meta">
				<time datetime={pubDate.toISOString()}>{formattedDate}</time>
				{author && <><span class="card-sep">·</span><span class="card-author">{author}</span></>}
			</div>
			<h2>{title}</h2>
			<p class="description">{description}</p>
			{tags && tags.length > 0 && (
				<ul class="tags">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)}
		</div>
	</a>
</article>

<style>
	/* Square-edged card: no border-radius on the container */
	.post-card {
		border: 1px solid var(--color-border);
		border-radius: 0;
		background: var(--color-bg);
		overflow: hidden;
		transition: border-color 0.15s;
	}

	.post-card:hover {
		border-color: var(--color-text);
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	/* Square cover image */
	.card-image {
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: transform 0.4s ease;
	}

	.card-link:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: var(--space-lg);
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-family: var(--font-ui);
		font-size: 0.75rem;
		color: var(--color-text-muted);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: var(--space-xs);
	}

	.card-sep {
		opacity: 0.4;
	}

	.card-author {
		color: var(--color-text-muted);
	}

	h2 {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		line-height: 1.2;
		margin: var(--space-xs) 0 var(--space-sm) 0;
		color: var(--color-text);
		letter-spacing: -0.01em;
	}

	.card-link:hover h2 {
		color: var(--color-accent);
	}

	.description {
		font-size: 0.95rem;
		color: var(--color-text-muted);
		margin: 0 0 var(--space-sm) 0;
		line-height: 1.6;
	}

	/* Editorial tag pills: no border-radius, 1px solid black border */
	.tags {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.tags li {
		font-family: var(--font-ui);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-text);
		background: transparent;
		border: 1px solid var(--color-text);
		border-radius: 0;
		padding: 3px 8px;
	}
</style>
