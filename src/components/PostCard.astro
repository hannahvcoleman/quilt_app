---
import { Image } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	slug: string;
	coverImage?: any;
	tags?: string[];
	author?: string;
}

const { title, description, pubDate, slug, coverImage, tags, author } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<article class="post-card">
	<a href={`${import.meta.env.BASE_URL}posts/${slug}`} class="card-link">
		{coverImage && typeof coverImage !== 'string' && (
			<div class="card-image">
				<Image src={coverImage} alt={title} loading="lazy" />
			</div>
		)}
		<div class="card-body">
			<div class="card-meta">
				<time datetime={pubDate.toISOString()}>{formattedDate}</time>
				{author && <><span class="card-sep">·</span><span class="card-author">{author}</span></>}
			</div>
			<h2>{title}</h2>
			<p class="description">{description}</p>
			{tags && tags.length > 0 && (
				<ul class="tags">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)}
		</div>
	</a>
</article>

<style>
	/* Sleek borderless card */
	.post-card {
		background: transparent;
		overflow: hidden;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.post-card:hover {
		opacity: 0.95;
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	/* Natural aspect ratio cover image */
	.card-image {
		width: 100%;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
		transition: transform 0.4s ease;
	}

	.card-link:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: var(--space-lg);
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-family: var(--font-ui);
		font-size: 0.70rem;
		color: var(--color-text-muted);
		letter-spacing: 0.02em;
		margin-bottom: var(--space-xs);
	}

	.card-sep {
		opacity: 0.4;
	}

	.card-author {
		color: var(--color-text-muted);
	}

	h2 {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		line-height: 1.2;
		margin: var(--space-xs) 0 var(--space-sm) 0;
		color: var(--color-text);
		letter-spacing: -0.01em;
	}

	.card-link:hover h2 {
		color: var(--color-accent);
	}

	.description {
		font-size: 0.95rem;
		color: var(--color-text-muted);
		margin: 0 0 var(--space-sm) 0;
		line-height: 1.6;
	}

	/* Sleek tag list */
	.tags {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tags li {
		font-family: var(--font-ui);
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--color-text-muted);
		background: transparent;
		border: none;
		padding: 0;
	}
	.tags li::before {
		content: '#';
		opacity: 0.5;
	}
</style>
