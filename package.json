{
  "name": "quilt-app",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.5.0"
  },
  "scripts": {
    "dev": "node scripts/sanitize-quotes.mjs && concurrently -n norm,astro -c cyan,blue --kill-others-on-fail \"node scripts/normalize-assets.mjs --watch\" \"astro dev\"",
    "prebuild": "node scripts/sanitize-quotes.mjs && node scripts/normalize-assets.mjs",
    "build": "rm -rf .astro && astro sync && astro build",
    "test": "vitest run",
    "preview": "astro preview",
    "astro": "astro",
    "import": "node scripts/import-notion.mjs",
    "lint:islands": "node scripts/hydration-linter.mjs"
  },
  "dependencies": {
    "@astrojs/markdoc": "^1.0.3",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.3",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "astro": "^6.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vitest": "^4.1.2"
  }
}
